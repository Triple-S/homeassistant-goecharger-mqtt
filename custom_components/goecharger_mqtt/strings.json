    "step": {
      "discovery_confirm": {
        "description": "[%key:common::config_flow::description%]"
      },
      "user": {
        "description": "[%key:common::config_flow::description%]",
        "data": {
          "topic": "MQTT topic",
          "charging_power": "Charging power"
        }
      },
